JWT_SECRET=replace-me-with-32-chars-minimum
REFRESH_SECRET=replace-me-with-32-chars-minimum
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://192.168.31.28:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://147.45.215.146

