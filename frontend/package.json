{
  "name": "void-bloom-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node ./scripts/clean-next.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "(test -d .next/types || npm run build >/dev/null) && tsc --noEmit",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "reset:dev": "npm run clean && npm run dev"
  },
  "dependencies": {
    "@heroui/react": "^2.8.9",
    "@tailwindcss/postcss": "^4.2.1",
    "@tanstack/react-query": "^5.64.2",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "next": "15.1.6",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwindcss": "^4.2.1",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "jsdom": "^28.1.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}
